ARG PY_VERSION=3.11
FROM quay.io/ascend/manylinux:8.5.1-910b-manylinux_2_28-py${PY_VERSION}

ARG SOC_VERSION="ascend910b1"

# Define environments
ENV DEBIAN_FRONTEND=noninteractive
ENV SOC_VERSION=$SOC_VERSION
ENV ASCEND_BUILD=1
ENV BUILD_WITH_EP=0

# Install build dependencies
RUN yum update -y && \
    yum install -y python3-pip git vim wget net-tools gcc gcc-c++ make cmake \
                   numactl-devel patchelf libcurl-devel unzip libzstd-devel && \
    rm -rf /var/cache/yum

WORKDIR /workspace

# Copy Mooncake source
COPY . /workspace/

# Install Python dependencies
RUN python3 -m pip install --upgrade pip setuptools wheel build auditwheel && \
    python3 -m pip install aiohttp requests

# Install project dependencies using vllm-ascend's installer (supports yum)
RUN wget -q https://raw.githubusercontent.com/vllm-project/vllm-ascend/main/tools/mooncake_installer.sh && \
    chmod +x mooncake_installer.sh && \
    bash mooncake_installer.sh -y

# Build and install gflags from source (yum version too old for CMake targets)
RUN cd /tmp && \
    git clone --depth 1 --branch v2.2.2 https://github.com/gflags/gflags.git && \
    cd gflags && \
    mkdir build && cd build && \
    cmake .. -DBUILD_SHARED_LIBS=ON -DBUILD_STATIC_LIBS=ON && \
    make -j$(nproc) && \
    make install && \
    ldconfig && \
    rm -rf /tmp/gflags

# Build Mooncake with Ascend support (same as vllm-ascend)
RUN source /usr/local/Ascend/ascend-toolkit/set_env.sh && \
    export LD_LIBRARY_PATH=/usr/local/Ascend/ascend-toolkit/latest/$(uname -i)-linux/devlib:/usr/local/Ascend/ascend-toolkit/latest/$(uname -i)-linux/lib64:$LD_LIBRARY_PATH && \
    git submodule update --init --recursive || true && \
    rm -rf build && mkdir -p build && cd build && \
    cmake .. -DUSE_ASCEND_DIRECT=ON && \
    make -j$(nproc) && \
    make install

# Build Python wheel
RUN source /usr/local/Ascend/ascend-toolkit/set_env.sh && \
    export LD_LIBRARY_PATH=/usr/local/Ascend/ascend-toolkit/latest/$(uname -i)-linux/devlib:/usr/local/Ascend/ascend-toolkit/latest/$(uname -i)-linux/lib64:$LD_LIBRARY_PATH:/usr/local/lib && \
    cd /workspace && \
    ./scripts/build_wheel.sh

# Show the built wheel
RUN ls -la /workspace/mooncake-wheel/dist/

CMD ["/bin/bash"]